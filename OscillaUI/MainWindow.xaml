<Window x:Class="OscillaUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:OscillaUI.Views" 
        Title="Oscilla." Height="650" Width="1100"
        Background="#121212" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Background="#444444" BorderThickness="0">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SidebarFuncButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4" Margin="6,2">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#252525"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PlaylistItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4" Margin="6,2">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#00FFCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="PlaylistDataTemplate">
            <Border CornerRadius="4" Background="Transparent" AllowDrop="True" Drop="Playlist_Drop">
                <Grid Height="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="12,0" Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}" TextTrimming="CharacterEllipsis"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="10,0" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}" Background="#111" Foreground="#00FFCC" BorderThickness="0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding DataContext.ConfirmRenameCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="&#xE70F;" FontFamily="Segoe MDL2 Assets" Command="{Binding DataContext.RenameCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" Foreground="#444" BorderThickness="0" Margin="0,0,5,0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="AllSongsTrackTemplate">
            <Grid Background="Transparent" MouseMove="Track_MouseMove" Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Format}" Foreground="#00FFCC" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                <TextBlock Text="{Binding DisplayName}" Grid.Column="1" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="12,0,0,0" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="LibraryItemTemplate">
            <Grid Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="■" Width="20" Foreground="{Binding StatusColor}" Background="Transparent" BorderThickness="0" Command="{Binding DataContext.ToggleLibraryCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Cursor="Hand"/>
                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
                <Button Grid.Column="2" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#AA2222" Background="Transparent" BorderThickness="0" Command="{Binding DataContext.RemoveLibraryCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Cursor="Hand"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid MouseLeftButtonDown="Window_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Oscilla." Foreground="#00FFCC" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="AUDIO ENGINE" Foreground="#555555" FontSize="11" Margin="10,0,0,4" VerticalAlignment="Bottom"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="—" Click="Minimize_Click" Width="40" Background="Transparent" Foreground="#666" BorderThickness="0"/>
                <Button Content="✕" Click="Close_Click" Width="40" Background="Transparent" Foreground="#666" BorderThickness="0"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Border BorderBrush="#202020" BorderThickness="1" CornerRadius="8" Background="#141414" Margin="0,0,0,10">
                    <StackPanel Margin="0,5">
                        <Button Content="AUDIO" Command="{Binding NavCommand}" CommandParameter="Audio" Style="{StaticResource SidebarFuncButton}"/>
                        <Button Content="LIBRARY" Command="{Binding NavCommand}" CommandParameter="Library" Style="{StaticResource SidebarFuncButton}"/>
                    </StackPanel>
                </Border>
                <Border BorderBrush="#202020" BorderThickness="1" CornerRadius="8" Background="#141414" Height="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Button Content="ALL SONGS" Command="{Binding NavCommand}" CommandParameter="AllSongs" Style="{StaticResource SidebarFuncButton}" FontWeight="Bold"/>
                        <ListBox Grid.Row="1" ItemsSource="{Binding CustomPlaylists}" SelectedItem="{Binding SelectedPlaylist}" ItemTemplate="{StaticResource PlaylistDataTemplate}" ItemContainerStyle="{StaticResource PlaylistItemStyle}" Background="Transparent" BorderThickness="0"/>
                        <Button Grid.Row="2" Content="+" Command="{Binding AddPlaylistCommand}" Style="{StaticResource SidebarFuncButton}" FontSize="20"/>
                    </Grid>
                </Border>
            </StackPanel>
            <Grid Grid.Column="1" Margin="15,0">
                <Border Visibility="{Binding CurrentView, ConverterParameter=AllSongs, Converter={StaticResource BoolToVis}}">
                    <ListBox ItemsSource="{Binding FilteredTracks}" SelectedItem="{Binding SelectedTrack}" ItemTemplate="{StaticResource AllSongsTrackTemplate}" ItemContainerStyle="{StaticResource PlaylistItemStyle}" Background="Transparent" BorderThickness="0" VirtualizingStackPanel.IsVirtualizing="True"/>
                </Border>
                <Border Visibility="{Binding CurrentView, ConverterParameter=PlaylistView, Converter={StaticResource BoolToVis}}">
                    <ListBox ItemsSource="{Binding SelectedPlaylist.Tracks}" SelectedItem="{Binding SelectedTrack}" ItemTemplate="{StaticResource AllSongsTrackTemplate}" ItemContainerStyle="{StaticResource PlaylistItemStyle}" Background="Transparent" BorderThickness="0" VirtualizingStackPanel.IsVirtualizing="True"/>
                </Border>
                <Border Visibility="{Binding CurrentView, ConverterParameter=Library, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Button Content="+ ADD FOLDER" Click="AddLibraryFolder_Click" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" Margin="0,0,10,10" Cursor="Hand"/>
                        <ListBox Grid.Row="1" ItemsSource="{Binding ActiveLibraries}" SelectedItem="{Binding SelectedLibrary}" ItemTemplate="{StaticResource LibraryItemTemplate}" ItemContainerStyle="{StaticResource PlaylistItemStyle}" Background="Transparent" BorderThickness="0"/>
                    </Grid>
                </Border>
            </Grid>
            <Grid Grid.Column="2">
                <Border BorderBrush="#202020" BorderThickness="1,0,0,0" Margin="15,10">
                    <StackPanel>
                        <TextBlock Text="PREVIEW" Foreground="#333" FontSize="10" FontWeight="Bold" Margin="0,0,0,20"/>
                        <Border Width="220" Height="220" Background="#181818" CornerRadius="8" BorderBrush="#252525" BorderThickness="1" Margin="0,0,0,20">
                            <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="64" Foreground="#222" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding SelectedTrack.DisplayName}" Foreground="White" FontSize="16" FontWeight="Bold" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        <views:PlayerBar Grid.Row="2"/>
    </Grid>
</Window>