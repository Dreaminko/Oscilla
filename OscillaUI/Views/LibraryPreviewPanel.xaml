<UserControl x:Class="OscillaUI.Views.LibraryPreviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="15,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock Text="LIBRARY INSIGHT" Foreground="#333333" FontSize="10" FontWeight="Bold" Margin="0,0,0,20"/>
            <Border Width="220" Height="100" Background="#181818" CornerRadius="8" BorderBrush="#252525" BorderThickness="1" Margin="0,0,0,20">
                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#00FFCC" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
            </Border>
            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16" FontWeight="Bold" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
            <Border Background="#222" Padding="8,4" CornerRadius="4" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock Text="{Binding Tracks.Count, StringFormat='{}{0} FILES'}" Foreground="#00FFCC" FontSize="10"/>
            </Border>
        </StackPanel>
        <ListBox Grid.Row="1" ItemsSource="{Binding Tracks}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Format}" Foreground="#444" FontSize="9" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="#888" FontSize="10" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>