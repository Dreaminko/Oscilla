<UserControl x:Class="Oscilla.UI.SourceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Oscilla.UI"
             Background="Transparent">

    <UserControl.RenderTransform>
        <TranslateTransform Y="0"/>
    </UserControl.RenderTransform>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="15" To="0" Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <UserControl.Resources>
        <local:LogTimeToRelativeConverter x:Key="LogTimeConverter"/>

        <LinearGradientBrush x:Key="AuroraBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#00FFAB" Offset="0"/>
            <GradientStop Color="#00D1FF" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="SourceToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Bg" Width="36" Height="18" Background="#111" BorderBrush="#333" BorderThickness="1" CornerRadius="9">
                            <Ellipse x:Name="Dot" Width="10" Height="10" Fill="#555" HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#111"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#00FFAB"/>
                                <Setter TargetName="Dot" Property="Fill" Value="#00FFAB"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Dot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="18" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Dot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0,0,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0,0,0,1" BorderBrush="#1A1A1A">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Bottom"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <Grid>
                                <Rectangle x:Name="Indicator" Width="3" Height="20" Fill="{StaticResource AuroraBrush}" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed" RadiusX="1.5" RadiusY="1.5"/>
                                <GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{TemplateBinding GridView.ColumnCollection}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A0A0A"/>
                                <Setter Property="Foreground" Value="#D1D1D1"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#111111"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <TextBlock x:Name="ViewTitle" Text="LIBRARY SOURCES" FontSize="32" FontWeight="Black" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="15,0,0,0"/>

                <!-- ==========================================
                     【对齐修正点】：通过 Stretch="Uniform" 实现绝对居中
                     ========================================== -->
                <Button x:Name="AddFolderBtn" Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0" Cursor="Hand" Click="AddFolder_Click" Background="Transparent">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent" BorderThickness="0" CornerRadius="16">
                                <!-- 修改：固定宽高的 Path + Uniform 拉伸确保在 Border 中绝对对准 -->
                                <Path x:Name="Icon" 
                                      Data="M 18,11 L 18,25 M 11,18 L 25,18" 
                                      Stroke="#888" 
                                      StrokeThickness="2.5" 
                                      Stretch="Uniform" 
                                      Width="14" Height="14"
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#1A1A1A"/>
                                    <Setter TargetName="Icon" Property="Stroke" Value="#FFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#111"/>
                                    <Setter TargetName="Icon" Property="Stroke" Value="#00FFAB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <ListView x:Name="SourceListView" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,10,0,0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="SourceListView_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="80">
                            <GridViewColumn.Header>
                                <TextBlock Text="STATUS" Margin="15,0,0,0"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource SourceToggle}" IsChecked="{Binding IsEnabled}" Margin="15,0,0,0" Click="Toggle_Click"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="260">
                            <GridViewColumn.Header>
                                <TextBlock Text="FOLDER NAME" Margin="15,0,0,0" VerticalAlignment="Bottom"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SourceName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding LogPath, Converter={StaticResource LogTimeConverter}}" 
                                                   Foreground="#777777" FontSize="10" FontWeight="Medium" 
                                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="280">
                            <GridViewColumn.Header>
                                <TextBlock Text="PATH" Margin="15,0,0,0"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FolderPath}" Foreground="#666" FontSize="11" TextTrimming="CharacterEllipsis" 
                                               VerticalAlignment="Center" Margin="15,0,0,0" Cursor="Hand" MouseLeftButtonDown="Path_MouseLeftButtonDown">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#AAA"/>
                                                        <Setter Property="TextDecorations" Value="Underline"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="80">
                            <GridViewColumn.Header>
                                <TextBlock Text="TRACKS" Margin="15,0,0,0"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Tracks.Count}" Foreground="#888" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="100">
                            <GridViewColumn.Header>
                                <TextBlock Text="ACTION" Margin="15,0,0,0"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="15,0,0,0" Background="Transparent">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <Button Style="{StaticResource ActionIconBtn}" Click="RefreshSource_Click" ToolTip="Refresh Log/Tracks">
                                            <Path Data="M 12,5 A 5,5 0 0 0 4,5 L 4,2 L 0,6 L 4,10 L 4,7 A 3,3 0 0 1 10,7 Z M 4,11 A 5,5 0 0 0 12,11 L 12,14 L 16,10 L 12,6 L 12,9 A 3,3 0 0 1 6,9 Z"
                                                  Stroke="#888" StrokeThickness="1.5" Stretch="Uniform" Width="12" Height="12" Fill="Transparent"/>
                                        </Button>

                                        <Button Style="{StaticResource ActionIconBtn}" Click="RemoveSource_Click" ToolTip="Remove Source">
                                            <Path Data="M 4,4 L 12,4 M 5,4 L 5,13 L 11,13 L 11,4 M 6.5,2 L 9.5,2 L 9.5,4 L 6.5,4 Z M 7,6 L 7,11 M 9,6 L 9,11"
                                                  Stroke="#FF4A4A" StrokeThickness="1.5" Stretch="Uniform" Width="12" Height="12" Fill="Transparent"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <Rectangle Grid.Column="1" Fill="#111111" VerticalAlignment="Stretch" Margin="0,20,0,20"/>

        <Grid Grid.Column="2" Margin="15,0,15,0" x:Name="RightPanelContainer" Opacity="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="SOURCE INFO" FontSize="15" FontWeight="Bold" Foreground="#444444" VerticalAlignment="Center" HorizontalAlignment="Left"/>

            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                <Border Width="190" Height="190" Background="#080808" BorderBrush="#1A1A1A" BorderThickness="1" CornerRadius="8" Margin="0,0,0,20" HorizontalAlignment="Center">
                    <TextBlock x:Name="FolderInitial" Text="" Foreground="#1E1E1E" FontSize="72" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="PreviewName" Text="NO SOURCE" FontSize="18" FontWeight="Bold" Foreground="#FFFFFF" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <TextBlock x:Name="PreviewStatus" Text="SELECT A FOLDER" FontSize="13" FontWeight="Medium" Foreground="#555" Margin="0,0,0,25"/>

                <Rectangle Height="1" Fill="#1A1A1A" Margin="0,0,0,20"/>

                <TextBlock Text="PROPERTIES" FontSize="11" FontWeight="Bold" Foreground="#555555" Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Total Tracks" Foreground="#666666" FontSize="12" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="PreviewTrackCount" Text="0" Foreground="#D1D1D1" FontSize="12" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Log File" Foreground="#666666" FontSize="12" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="PreviewLogStatus" Text="--" Foreground="#D1D1D1" FontSize="12" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>