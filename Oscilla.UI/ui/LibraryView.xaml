<UserControl x:Class="Oscilla.UI.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             x:Name="ViewRoot">

    <UserControl.RenderTransform>
        <TranslateTransform Y="0"/>
    </UserControl.RenderTransform>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="15" To="0" Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <UserControl.Resources>
        <!-- 控制垃圾桶在特定情况下才显示的转换器 -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 极光色渐变 -->
        <LinearGradientBrush x:Key="AuroraBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#00FFAB" Offset="0"/>
            <GradientStop Color="#00D1FF" Offset="1"/>
        </LinearGradientBrush>

        <!-- 自定义滚动条 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent">
                            <Track IsDirectionReversed="True" x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#404040" CornerRadius="0.75" Width="1.5" HorizontalAlignment="Right" Margin="0,0,2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 列表表头样式 -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0,0,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0,0,0,1" BorderBrush="#1A1A1A">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Bottom"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 支持“排队进入”动画的 ListViewItem -->
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>

            <!-- 动画预设：初始状态 Y 轴下移 20 像素，透明度为 0 -->
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="20"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Opacity" Value="0"/>

            <EventSetter Event="MouseEnter" Handler="ListViewItem_MouseEnter"/>
            <EventSetter Event="MouseLeave" Handler="ListViewItem_MouseLeave"/>
            <EventSetter Event="MouseDoubleClick" Handler="ListViewItem_MouseDoubleClick"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <Grid>
                                <Rectangle x:Name="Indicator" Width="3" Height="20" Fill="{StaticResource AuroraBrush}" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed" RadiusX="1.5" RadiusY="1.5"/>
                                <GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{TemplateBinding GridView.ColumnCollection}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A0A0A"/>
                                <Setter Property="Foreground" Value="#D1D1D1"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#111111"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- 核心动画：当 Item 加载时，触发“浮现并上移” -->
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.4">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TextOnlyCheckbox" TargetType="CheckBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#D1D1D1"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#00FFAB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 功能图标按钮的基础样式 -->
        <Style x:Key="ActionIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <TextBlock x:Name="ViewTitle" Text="LOCAL LIBRARY" FontSize="32" FontWeight="Black" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="15,0,0,0"/>

                <StackPanel x:Name="SearchFilterContainer" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Border Background="#0A0A0A" BorderBrush="#1E1E1E" BorderThickness="1" CornerRadius="6" Width="200" Height="36" Margin="0,0,10,0">
                        <Grid>
                            <TextBlock x:Name="SearchPlaceholder" Text="Search tracks..." Foreground="#444444" VerticalAlignment="Center" Margin="35,0,0,0" IsHitTestVisible="False"/>
                            <Path Data="M 10,10 L 14,14 M 6,11 C 3.2385763,11 1,8.7614237 1,6 C 1,3.2385763 3.2385763,1 6,1 C 8.7614237,1 11,3.2385763 11,6 C 11,8.7614237 8.7614237,11 6,11 Z" Stroke="#555" StrokeThickness="1.5" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" Background="Transparent" Foreground="#FFF" BorderThickness="0" VerticalAlignment="Center" Margin="35,0,10,0" CaretBrush="#00FFAB"/>
                        </Grid>
                    </Border>

                    <ToggleButton x:Name="FilterBtn" Width="36" Height="36" Cursor="Hand" Background="Transparent">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="Bg" Background="#0A0A0A" BorderBrush="#1E1E1E" BorderThickness="1" CornerRadius="6">
                                    <Path x:Name="Icon" Data="M 2,3 L 14,3 L 9,9 L 9,14 L 7,16 L 7,9 Z" Stroke="#888" StrokeThickness="1.5" Fill="Transparent" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#1A1A1A"/>
                                        <Setter TargetName="Icon" Property="Stroke" Value="#FFF"/>
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#111111"/>
                                        <Setter TargetName="Bg" Property="BorderBrush" Value="#00FFAB"/>
                                        <Setter TargetName="Icon" Property="Stroke" Value="#00FFAB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </StackPanel>

                <Popup IsOpen="{Binding IsChecked, ElementName=FilterBtn}" PlacementTarget="{Binding ElementName=SearchFilterContainer}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide" VerticalOffset="10">
                    <Border Background="#0A0A0A" BorderBrush="#1E1E1E" BorderThickness="1" CornerRadius="8" Width="246" Padding="20" Margin="0,0,10,10">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" BlurRadius="20" Opacity="0.8" Direction="270" ShadowDepth="5"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="FILE FORMAT" Foreground="#555" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                            <UniformGrid Columns="2">
                                <CheckBox x:Name="ChkFlac" Content="FLAC" Style="{StaticResource TextOnlyCheckbox}" Click="Filter_Changed"/>
                                <CheckBox x:Name="ChkWav" Content="WAV" Style="{StaticResource TextOnlyCheckbox}" Click="Filter_Changed"/>
                                <CheckBox x:Name="ChkMp3" Content="MP3" Style="{StaticResource TextOnlyCheckbox}" Click="Filter_Changed"/>
                                <CheckBox x:Name="ChkAac" Content="AAC" Style="{StaticResource TextOnlyCheckbox}" Click="Filter_Changed"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>

            <ListView x:Name="TrackListView" 
                      Grid.Row="1" 
                      Background="Transparent" 
                      BorderThickness="0" 
                      Margin="0,10,0,0" 
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                      SelectionChanged="TrackListView_SelectionChanged"
                      PreviewMouseLeftButtonDown="TrackListView_PreviewMouseLeftButtonDown"
                      PreviewMouseMove="TrackListView_PreviewMouseMove"
                      Tag="{Binding ElementName=ViewRoot, Path=IsCustomPlaylist}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="60">
                            <GridViewColumn.Header>
                                <TextBlock Text="TYPE"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Format}" Foreground="#666666" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="260">
                            <GridViewColumn.Header>
                                <TextBlock Text="TITLE"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- 这里是修改过的支持点击和变色的 ARTIST 列 -->
                        <GridViewColumn Width="180">
                            <GridViewColumn.Header>
                                <TextBlock Text="ARTIST"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Artist}" VerticalAlignment="Center" Margin="15,0,0,0" 
                                               Cursor="Hand" MouseLeftButtonUp="ArtistText_MouseLeftButtonUp" Background="Transparent">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#00FFAB"/>
                                                        <Setter Property="TextDecorations" Value="Underline"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="80">
                            <GridViewColumn.Header>
                                <TextBlock Text="TIME"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Duration}" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="150">
                            <GridViewColumn.Header>
                                <TextBlock Text="FORMAT"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="#555" FontSize="11" VerticalAlignment="Center" Margin="15,0,0,0">
                                        <Run Text="{Binding SampleRate, StringFormat={}{0:0.0}kHz}"/>
                                        <Run Text=" / "/>
                                        <Run Text="{Binding BitDepth, StringFormat={}{0}bit}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <Rectangle Grid.Column="1" Fill="#111111" VerticalAlignment="Stretch" Margin="0,20,0,20"/>

        <Grid Grid.Column="2" Margin="15,0,15,0" x:Name="RightPanelContainer">
            <Grid.RenderTransform>
                <TranslateTransform Y="0"/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="PreviewHeaderTitle" Text="INFO" FontSize="15" FontWeight="Bold" Foreground="#444444" VerticalAlignment="Center" HorizontalAlignment="Left"/>

            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                <Border Width="190" Height="190" Background="#080808" BorderBrush="#1A1A1A" BorderThickness="1" CornerRadius="8" Margin="0,0,0,20" HorizontalAlignment="Center">
                    <TextBlock x:Name="CoverInitial" Text="" Foreground="#1E1E1E" FontSize="72" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="PreviewTitle" Text="NO TRACK" FontSize="18" FontWeight="Bold" Foreground="#FFFFFF" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <TextBlock x:Name="PreviewArtist" Text="SELECTED" FontSize="13" FontWeight="Medium" Foreground="#00FFAB" Margin="0,0,0,25"/>

                <Rectangle Height="1" Fill="#1A1A1A" Margin="0,0,0,20"/>

                <TextBlock Text="PROPERTIES" FontSize="11" FontWeight="Bold" Foreground="#555555" Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Duration" Foreground="#666666" FontSize="12" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="PreviewDuration" Text="--:--" Foreground="#D1D1D1" FontSize="12" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Sample Rate" Foreground="#666666" FontSize="12" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="PreviewSampleRate" Text="--.- kHz" Foreground="#D1D1D1" FontSize="12" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Bit Depth" Foreground="#666666" FontSize="12" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="PreviewBitDepth" Text="-- bit" Foreground="#D1D1D1" FontSize="12" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- ==========================================
             【新增】：全局拦截的删除确认层（超酷黑透遮罩）
             ========================================== -->
        <Grid x:Name="TrackDeleteOverlay" Grid.ColumnSpan="3" Background="#A5000000" Visibility="Collapsed" Panel.ZIndex="100" Opacity="0">
            <Border Background="#151515" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="25,25,25,20" Width="360">
                <Border.Effect>
                    <DropShadowEffect Color="#000" BlurRadius="30" Opacity="0.9" Direction="270" ShadowDepth="10"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="REMOVE TRACK" FontSize="15" FontWeight="Black" Foreground="#FF4A4A" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DeleteTrackPromptText" Text="Are you sure you want to remove this track?" Foreground="#D1D1D1" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,30" LineHeight="20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- 自定义手写按钮，规避系统自带丑陋 Button 样式 -->
                        <Border Background="Transparent" Cursor="Hand" Margin="0,0,15,0" PreviewMouseDown="CancelTrackDelete_Click">
                            <TextBlock Text="CANCEL" Foreground="#888888" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" Padding="15,8"/>
                        </Border>
                        <Border Background="#FF4A4A" CornerRadius="6" Cursor="Hand" PreviewMouseDown="ConfirmTrackDelete_Click">
                            <TextBlock Text="REMOVE" Foreground="#111111" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Padding="20,8"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>