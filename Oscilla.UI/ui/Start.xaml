<UserControl x:Class="Oscilla.UI.Start"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#050505">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="AuroraTextBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#00FFAB" Offset="0"/>
            <GradientStop Color="#00D1FF" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Resources>

    <Grid>
        <Ellipse x:Name="Ring" 
                 Width="240" Height="240" 
                 Stroke="{StaticResource AuroraTextBrush}"
                 StrokeThickness="42"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="ScaleRing" ScaleX="0.9" ScaleY="0.9"/>
            </Ellipse.RenderTransform>
        </Ellipse>
    </Grid>
</UserControl>