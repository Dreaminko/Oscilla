<UserControl x:Class="Oscilla.UI.OverlayRemoveSource"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid Background="#E5000000">
        <Border Background="#111111" BorderBrush="#2E2E2E" BorderThickness="1" 
                CornerRadius="12" Width="350" Height="180" 
                HorizontalAlignment="Center" VerticalAlignment="Center">

            <StackPanel VerticalAlignment="Center" Margin="20">
                <TextBlock Text="移除库源" Foreground="#FF4A4A" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ConfirmText" Text="确定要移除该音乐库吗？" Foreground="#A0A0A0" 
                           FontSize="13" Margin="0,20,0,30" HorizontalAlignment="Center" TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="取消" Click="Cancel_Click" Style="{StaticResource DialogBtnStyle}" Margin="0,0,15,0"/>
                    <Button Content="确定移除" Click="Confirm_Click" Style="{StaticResource DialogBtnStyle}" Foreground="#FF4A4A" Width="90"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>