<UserControl x:Class="Oscilla.UI.OverlayChangeDiff"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid Background="#E5000000">
        <Border Background="#111111" BorderBrush="#1F1F1F" BorderThickness="1" 
                CornerRadius="16" Width="650" Height="500" 
                HorizontalAlignment="Center" VerticalAlignment="Center">

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="StatusTitle" Grid.Row="0" 
                           Text="同步完成！变动报告明细：" 
                           Foreground="#00D1FF" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#2200FFAB" BorderThickness="1" CornerRadius="8" Padding="10" Background="#0A0A0A">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="✨ 新增歌曲" Foreground="#00FFAB" FontWeight="Bold" Margin="0,0,0,8"/>
                            <ListBox Grid.Row="1" x:Name="NewFilesList" Background="Transparent" BorderThickness="0" Foreground="#A0A0A0" FontSize="12"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" BorderBrush="#22FF4A4A" BorderThickness="1" CornerRadius="8" Padding="10" Background="#0A0A0A">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="🗑️ 移除/丢失歌曲" Foreground="#FF4A4A" FontWeight="Bold" Margin="0,0,0,8"/>
                            <ListBox Grid.Row="1" x:Name="MissingFilesList" Background="Transparent" BorderThickness="0" Foreground="#A0A0A0" FontSize="12"/>
                        </Grid>
                    </Border>
                </Grid>

                <Button Grid.Row="2" Content="完成同步" Click="Dismiss_Click"
                        Width="100" Height="32" Margin="0,15,0,0" Cursor="Hand"
                        Background="#222222" Foreground="#FFFFFF" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>