<UserControl x:Class="Oscilla.UI.OverlayTrackCards"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid Background="#E5000000">
        <Border Background="#111111" BorderBrush="#1F1F1F" BorderThickness="1" 
                CornerRadius="16" Width="600" Height="450" 
                HorizontalAlignment="Center" VerticalAlignment="Center">

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TitleText" Grid.Row="0" 
                           Text="新音乐库扫描成功！" 
                           Foreground="#00FFAB" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Focusable="False">
                    <ItemsControl x:Name="CardsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#161616" Margin="0,4" Padding="12,8" CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Title}" Foreground="#FFFFFF" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Artist}" Foreground="#666666" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Format}" Foreground="#00D1FF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="2" Content="一键载入大厅" Click="Close_Click"
                        Width="120" Height="36" Margin="0,15,0,0" Cursor="Hand"
                        Background="#00FFAB" Foreground="#000000" FontWeight="Bold" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>