<UserControl x:Class="Oscilla.UI.OverlayAddExist"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid Background="#B2000000">
        <Border Background="#111111" BorderBrush="#2E2E2E" BorderThickness="1" 
                CornerRadius="12" Width="320" Height="160" 
                HorizontalAlignment="Center" VerticalAlignment="Center">

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="MessageText" Grid.Row="0"
                           Text="该文件夹已在您的音乐库中" 
                           Foreground="#FFFFFF" FontSize="14" FontWeight="Medium" 
                           HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"/>

                <Button Grid.Row="1" Content="确定" Click="Confirm_Click"
                        Width="80" Height="30" Cursor="Hand"
                        Background="#222222" Foreground="#00FFAB" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>