<UserControl x:Class="Oscilla.UI.NavigationSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220" Background="#050505">

    <UserControl.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent">
                            <Track IsDirectionReversed="True" x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#404040" CornerRadius="0.75" Width="1.5" HorizontalAlignment="Right" Margin="0,0,2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ScrollViewer}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.8"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AddBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1A1A"/>
                    <Setter Property="Foreground" Value="#00FFAB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="GroupName" Value="MainNav"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <Grid>
                                <Rectangle Name="Indicator" Width="3" Height="18" Fill="#00FFAB" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed" RadiusX="1.5" RadiusY="1.5"/>
                                <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#D1D1D1"/>
                                <Setter Property="Background" Value="#111111"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="Background" Value="#1A1A1A"/>
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                <Path x:Name="Arrow" Data="M 0,0 L 4,4 L 8,0" Stroke="#555555" StrokeThickness="1.5" Fill="Transparent" Stretch="None" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#D1D1D1"/>
                                <Setter Property="Background" Value="#111111"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="Data" Value="M 0,4 L 4,0 L 8,4"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubNavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#777777"/>
            <Setter Property="GroupName" Value="MainNav"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <Grid>
                                <Rectangle Name="Indicator" Width="3" Height="14" Fill="#00FFAB" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed" RadiusX="1.5" RadiusY="1.5"/>
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="44,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#D1D1D1"/>
                                <Setter Property="Background" Value="#111111"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,30,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <RadioButton Style="{StaticResource NavButtonStyle}" Tag="Library" Checked="NavButton_Checked">
                <StackPanel Orientation="Horizontal" Margin="15,0,0,0">
                    <Path Data="M 0,2 L 5,2 L 7,0 L 14,0 L 14,12 L 0,12 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="1.5" Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Library" Margin="15,0,0,0" FontSize="13" VerticalAlignment="Center" FontWeight="Medium"/>
                </StackPanel>
            </RadioButton>

            <ToggleButton x:Name="AudioExpander" Style="{StaticResource MenuToggleStyle}" IsChecked="False" Checked="AudioExpander_Checked" Unchecked="AudioExpander_Unchecked">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M 0,10 L 4,10 M 0,5 L 4,5 M 0,15 L 4,15 M 10,0 L 10,20" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" StrokeThickness="1.5" Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Audio" Margin="15,0,0,0" FontSize="13" VerticalAlignment="Center" FontWeight="Medium"/>
                </StackPanel>
            </ToggleButton>

            <StackPanel x:Name="AudioSubMenuContainer">
                <StackPanel.LayoutTransform>
                    <ScaleTransform ScaleY="0" x:Name="AudioSubMenuScale"/>
                </StackPanel.LayoutTransform>
                <RadioButton Style="{StaticResource SubNavButtonStyle}" Tag="Visualizer" Checked="NavButton_Checked">
                    <TextBlock Text="Visualizer" FontSize="12" FontWeight="Medium"/>
                </RadioButton>
                <RadioButton Style="{StaticResource SubNavButtonStyle}" Tag="Equalizer" Checked="NavButton_Checked">
                    <TextBlock Text="Equalizer" FontSize="12" FontWeight="Medium"/>
                </RadioButton>
            </StackPanel>

            <Canvas Height="30"/>

            <Grid Margin="10,2">
                <RadioButton Style="{StaticResource NavButtonStyle}" Tag="AllSongs" Checked="NavButton_Checked" Margin="0">
                    <StackPanel Orientation="Horizontal" Margin="15,0,0,0">
                        <Path Data="M 2,0 L 14,0 M 0,5 L 14,5 M 0,10 L 10,10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="1.5" Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="All Songs" Margin="15,0,0,0" FontSize="13" VerticalAlignment="Center" FontWeight="Medium"/>
                    </StackPanel>
                </RadioButton>
                <Button Style="{StaticResource AddBtnStyle}" HorizontalAlignment="Right" Margin="0,0,10,0" Click="AddPlaylist_Click">
                    <Path Data="M 5,0 L 5,10 M 0,5 L 10,5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Stretch="Uniform" Width="10" Height="10"/>
                </Button>
            </Grid>
        </StackPanel>

        <ScrollViewer x:Name="NavScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,5,0,10" PreviewMouseWheel="NavScrollViewer_PreviewMouseWheel">
            <StackPanel x:Name="PlaylistsContainer" />
        </ScrollViewer>
    </Grid>
</UserControl>