<UserControl x:Class="Oscilla.UI.PlayerBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             Height="80" VerticalAlignment="Bottom">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="AuroraFlowBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#00FFAB" Offset="0.0" />
            <GradientStop Color="#00D1FF" Offset="0.5" />
            <GradientStop Color="#00FFAB" Offset="1.0" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="AuroraStaticBrush" Color="#00FFAB"/>
        <SolidColorBrush x:Key="AuroraFaintBrush" Color="#CC00FFAB"/>
        <SolidColorBrush x:Key="GrayInactiveBrush" Color="#A0A0A0"/>
        <SolidColorBrush x:Key="GrayTextBrush" Color="#888888"/>
        <SolidColorBrush x:Key="HoverGrayBrush" Color="#D1D1D1"/>

        <Style x:Key="GeometricBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#3F3F3F"/>
            <Setter Property="Foreground" Value="{StaticResource GrayInactiveBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource HoverGrayBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource HoverGrayBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlayerSliderStyle" TargetType="Slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="12">
                            <Border Height="2" Background="#1A1A1A" CornerRadius="1" VerticalAlignment="Center"/>
                            <Track Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border x:Name="ElapsedTrack" Background="{StaticResource GrayInactiveBrush}" Height="2" CornerRadius="1" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" Height="2" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid Background="Transparent" Width="12" Height="12">
                                                    <Ellipse Width="5" Height="5" Fill="{StaticResource HoverGrayBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Cursor="Hand"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12,6,12,8">
        <Border BorderThickness="2" BorderBrush="#3F3F3F" CornerRadius="10" Background="#000000" />
        <Border Name="AuroraBorder" BorderThickness="2" BorderBrush="{StaticResource AuroraFlowBrush}" CornerRadius="10" Opacity="0" IsHitTestVisible="False"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="15,2,15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Name="TimeDot" Width="6" Height="6" Fill="#3F3F3F" Margin="0,0,8,0"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Name="CurrentTimeText" Text="00:00" Foreground="{StaticResource GrayTextBrush}" FontSize="13" FontWeight="Medium"/>
                        <TextBlock Text=" / " Foreground="#3F3F3F" FontSize="13"/>
                        <TextBlock Name="TotalTimeText" Text="00:00" Foreground="#3F3F3F" FontSize="13"/>
                    </StackPanel>
                    <Rectangle Width="1" Height="10" Fill="#2E2E2E" Margin="12,0"/>
                    <TextBlock Name="TrackNameText" Text="NO TRACK LOADED" Foreground="{StaticResource GrayTextBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Name="AudioSpecs" Text="---kbps | --.-kHz | --bit" Foreground="#3F3F3F" FontSize="11" VerticalAlignment="Center" Margin="0,0,15,0"/>

                    <!-- 【新增】：ASIO / NORM 切换按钮，宽度设为 46 以适应文字 -->
                    <Button Name="OutputModeBtn" Content="NORM" Foreground="{StaticResource GrayInactiveBrush}" Width="46" Height="34" FontSize="11" FontWeight="SemiBold" Click="OutputModeBtn_Click" Style="{StaticResource GeometricBtnStyle}" Margin="0,0,10,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>

                    <Button Name="LoopModeBtn" Content="all" Foreground="{StaticResource GrayTextBrush}" Width="34" Height="34" FontSize="12" Click="LoopMode_Click" Style="{StaticResource GeometricBtnStyle}" Margin="0,0,10,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>

                    <Button Name="VolumeBtn" Width="34" Height="34" Click="VolumeBtn_Click" Style="{StaticResource GeometricBtnStyle}" Margin="0,0,20,0" ClipToBounds="True" HorizontalContentAlignment="Left" VerticalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal" Width="150" Background="Transparent">
                            <TextBlock Name="VolumeText" Text="50" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                                       FontSize="13" FontWeight="SemiBold" Width="34" TextAlignment="Center" VerticalAlignment="Center" Margin="0,1,0,0"/>
                            <Slider Name="VolumeSlider" Style="{StaticResource PlayerSliderStyle}" Minimum="0" Maximum="100" Value="50" Width="100" 
                                    VerticalAlignment="Center" Margin="5,0,0,0"
                                    ValueChanged="VolumeSlider_ValueChanged"
                                    PreviewMouseDown="VolumeSlider_PreviewMouseDown"
                                    PreviewMouseUp="VolumeSlider_PreviewMouseUp" />
                        </StackPanel>
                    </Button>

                    <Button Name="PrevBtn" Width="34" Height="34" Click="PrevBtn_Click" Style="{StaticResource GeometricBtnStyle}" Margin="0,0,5,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <Path Data="M 0,0 L 3,0 L 3,14 L 0,14 Z M 4,7 L 13,0 L 13,14 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Fill="Transparent" StrokeThickness="1.5" Stretch="Uniform" Width="12" Height="12"/>
                    </Button>
                    <Button Name="NextBtn" Width="34" Height="34" Click="NextBtn_Click" Style="{StaticResource GeometricBtnStyle}" Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <Path Data="M 1,0 L 1,14 L 10,7 Z M 11,0 L 14,0 L 14,14 L 11,14 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Fill="Transparent" StrokeThickness="1.5" Stretch="Uniform" Width="12" Height="12"/>
                    </Button>
                    <Button Name="ToggleBtn" Width="34" Height="34" Click="ToggleBtn_Click" Style="{StaticResource GeometricBtnStyle}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <Path Name="ToggleIconPath" Data="M 2,0 L 14,7 L 2,14 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Fill="Transparent" StrokeThickness="1.5" Stretch="Uniform" Width="10" Height="12"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="15,0,15,4">
                <Slider Name="TimelineSlider" 
                        Style="{StaticResource PlayerSliderStyle}" 
                        Minimum="0" Maximum="1000" Value="0" 
                        IsMoveToPointEnabled="True" Cursor="Hand"
                        Thumb.DragStarted="TimelineSlider_DragStarted" 
                        Thumb.DragCompleted="TimelineSlider_DragCompleted"
                        ValueChanged="TimelineSlider_ValueChanged"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>